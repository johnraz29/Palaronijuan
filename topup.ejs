<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Top Up</title>
<link rel="stylesheet" href="/topup.css" />
</head>

<body>

<div class="background"></div>

<header class="top-header">
    <div class="logo">
        <img src="/images/logo.png" alt="Logo">
        <h1>Wallet Top‑Up</h1>
    </div>
</header>

<main class="container">

<div class="topup-card">

<h2>Top‑up Balance</h2>

<p class="description">
Enter the amount you want to top up and your <strong>GCash payment reference</strong>.
After sending the payment externally, wait for the admin to verify your request.
</p>

<form method="post" action="/topup" id="topupForm">

<div class="form-group">
<label>Amount (PHP)</label>
<input 
name="amount"
id="amount"
type="number"
min="50"
max="100000"
step="1"
placeholder="Enter amount (₱50 - ₱100,000)"
required>
<small>Minimum ₱50 • Maximum ₱100,000</small>
</div>

<div class="form-group">
<label>GCash Payment Reference</label>
<input 
name="reference"
type="text"
placeholder="Enter GCash reference number"
required>
</div>

<button type="submit" class="topup-btn">
Submit Top‑Up Request
</button>

</form>

</div>

</main>

<script>
const amountInput = document.getElementById("amount");

amountInput.addEventListener("input", function () {

    // remove non numbers
    this.value = this.value.replace(/[^0-9]/g, "");

    if (this.value > 100000) {
        this.value = 100000;
    }

});
</script>

</body>
</html>