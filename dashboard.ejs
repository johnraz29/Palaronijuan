<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dashboard</title>
<link rel="stylesheet" href="/dashboard.css" />
<style>
/* Jackpot styling */
#jackpot-container {
    text-align: center;
    margin: 30px 0;
    font-family: 'Arial Black', sans-serif;
}

#jackpot-label {
    font-size: 1.5em;
    color: #ffdd00;
    text-shadow: 2px 2px 5px black;
}

#jackpot-amount {
    font-size: 2.5em;
    font-weight: bold;
    color: #ff4500;
    text-shadow: 2px 2px 10px black;
    animation: glow 1.5s ease-in-out infinite alternate;
}

@keyframes glow {
    from { text-shadow: 2px 2px 10px #ff4500, 0 0 20px #ff4500; }
    to { text-shadow: 2px 2px 20px #ff6347, 0 0 30px #ff6347; }
}
</style>
</head>
<body>
<header>
    <div class="logo">
    <img src="LOGO_123.png" alt="Dashboard logo emblem for My Dashboard application" />
     <h1>My Dashboard</h1>
    </div>
    <div class="user-info">
        <p>Hello, <strong><%= user.name %></strong> — Balance: 
        <span class="balance">₱<%= (user.balance||0).toFixed(2) %></span></p>
    </div>
</header>

<!-- Jackpot display -->
<div id="jackpot-container">
    <div id="jackpot-label">🎉 Jackpot Prize 🎉</div>
    <div id="jackpot-amount">₱0.00</div>
</div>
<% if (result) { %>
<div style="text-align:center;margin-top:20px;">
    <h2>🎯 Latest Draw Result</h2>
    <h3><%= result.numbers %></h3>
</div>
<% } %>
<nav class="dashboard-tabs">
    <button class="tab-btn active" data-target="dashboard-section">Dashboard</button>
    <button class="tab-btn" data-target="bets-section">Your Bets</button>
    <button class="tab-btn" data-target="transactions-section">Transactions</button>
</nav>

<main>
    <section id="dashboard-section" class="tab-section active">
        <h2>Dashboard Overview</h2>
        <p>Welcome back, <strong><%= user.name %></strong>! Here's a quick look at your account.</p>
    </section>

    <section id="bets-section" class="tab-section">
        <h2>Your Bets</h2>
        <table>
            <thead>
                <tr><th>#</th><th>Numbers</th><th>Amount</th><th>Status</th><th>When</th></tr>
            </thead>
            <tbody>
            <% if (bets && bets.length) { bets.forEach(b=>{ %>
                <tr>
                    <td><%= b.id %></td>
                    <td><%= b.numbers %></td>
                    <td>₱<%= b.amount %></td>
                    <td><%= b.status %></td>
                    <td><%= b.created_at %></td>
                </tr>
            <% }) } else { %>
                <tr><td colspan="5">No bets yet</td></tr>
            <% } %>
            </tbody>
        </table>
    </section>

    <section id="transactions-section" class="tab-section">
        <h2>Transactions</h2>
        <table>
            <thead>
                <tr><th>Type</th><th>Amount</th><th>Status</th><th>Ref</th><th>When</th></tr>
            </thead>
            <tbody>
            <% if (txs && txs.length) { txs.forEach(t=>{ %>
                <tr>
                    <td><%= t.type %></td>
                    <td>₱<%= t.amount %></td>
                    <td><%= t.status %></td>
                    <td><%= t.reference %></td>
                    <td><%= t.created_at %></td>
                </tr>
            <% }) } else { %>
                <tr><td colspan="5">No transactions</td></tr>
            <% } %>
            </tbody>
        </table>
    </section>
</main>

<footer>
    <p>&copy; <%= new Date().getFullYear() %> My Dashboard. All rights reserved.</p>
</footer>

<script>
    // Tab switching
    const tabs = document.querySelectorAll('.tab-btn');
    const sections = document.querySelectorAll('.tab-section');
    tabs.forEach(tab => {
        tab.addEventListener('click', () => {
            tabs.forEach(t => t.classList.remove('active'));
            sections.forEach(s => s.classList.remove('active'));
            tab.classList.add('active');
            document.getElementById(tab.dataset.target).classList.add('active');
        });
    });

    // Animated jackpot counter
    const jackpotEl = document.getElementById('jackpot-amount');
    let jackpotValue = 0; // initial for animation
    const finalJackpot = <%= jackpot || 100000 %>; // value passed from server
    const increment = Math.max(finalJackpot / 100, 1); // smooth increment

    function animateJackpot() {
        if (jackpotValue < finalJackpot) {
            jackpotValue += increment;
            if (jackpotValue > finalJackpot) jackpotValue = finalJackpot;
            jackpotEl.textContent = '₱' + jackpotValue.toLocaleString(undefined, {minimumFractionDigits:2, maximumFractionDigits:2});
            requestAnimationFrame(animateJackpot);
        }
    }
    animateJackpot();
</script>
<% if (userWon) { %>
setTimeout(() => {
    alert("🎉 CONGRATULATIONS! You won the lottery jackpot!");
}, 1000);
<% } %>
</body>
</html>